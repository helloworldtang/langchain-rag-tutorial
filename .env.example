# ========================================
# LangChain RAG 项目环境变量配置模板
# ========================================
# 用法：复制本文件为 .env，填入真实值。.env 已被 .gitignore 忽略，不会提交。
#   cp .env.example .env

# ===== LLM Provider 切换 =====
# ollama（默认，本地离线、免费） | deepseek（在线，需下方 API Key）
LLM_PROVIDER=ollama

# ===== DeepSeek 在线模型配置 =====
# API Key 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# DeepSeek 模型选择：
#   deepseek-chat     —— V3.1，通用对话，便宜（约 $0.14/1M 输入 token）
#   deepseek-reasoner —— 推理型，会返回 reasoning_content（思考过程）
DEEPSEEK_MODEL=deepseek-chat

# ===== Ollama 本地模型（LLM_PROVIDER=ollama 时使用） =====
OLLAMA_LLM_MODEL=deepseek-r1:1.5b

# ===== Embedding 模型（始终本地 Ollama，与 LLM_PROVIDER 无关） =====
# DeepSeek 不提供 Embedding API，因此两种 provider 下都用本地 Ollama 做 embedding。
# 换模型（如 bge-m3）需先 ollama pull，且会触发 FAISS 索引重建。
EMBED_MODEL=nomic-embed-text

# 注：请确保 ollama serve 运行且已拉取 EMBED_MODEL 指定的模型。
